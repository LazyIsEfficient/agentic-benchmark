{
  "name": "ticket-tracker",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "A small support-ticket tracker: Express + Prisma (SQLite) API with a vanilla HTML/JS frontend.",
  "scripts": {
    "postinstall": "prisma generate",
    "setup": "prisma migrate deploy && node prisma/seed.js",
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "test": "echo \"No tests yet\" && exit 0"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "express": "^4.22.2"
  },
  "devDependencies": {
    "prisma": "^6.19.3"
  }
}
