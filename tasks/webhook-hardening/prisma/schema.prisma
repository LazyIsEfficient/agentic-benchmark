// Webhook ingress data model.
// SQLite in local/dev; the same schema runs on the managed SQL database in prod.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// A payment-provider webhook delivery recorded in the ledger.
/// eventId is the provider's delivery id — not unique yet (idempotency TBD).
model PaymentEvent {
  id        String   @id @default(uuid())
  eventId   String
  type      String
  amount    Int
  currency  String   @default("usd")
  createdAt DateTime @default(now())
}
