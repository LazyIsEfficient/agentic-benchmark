# Revenue Intelligence — environment configuration
# Copy to .env and fill in your values. See references/configuration.md.

# --- Required ---
# Gong (scripts/gong_insight_pipeline.py, scripts/client_report_generator.py)
GONG_API_KEY=your-gong-api-key-here
GONG_API_BASE_URL=https://api.gong.io/v2

# HubSpot (scripts/revenue_attribution.py, scripts/client_report_generator.py)
HUBSPOT_API_KEY=your-hubspot-private-app-token-here

# GA4 (scripts/revenue_attribution.py, scripts/client_report_generator.py)
GA4_PROPERTY_ID=your-ga4-property-id-here
GA4_CREDENTIALS_JSON=/absolute/path/to/ga4-service-account.json

# --- Optional ---
# Ahrefs (scripts/client_report_generator.py)
AHREFS_TOKEN=your-ahrefs-api-token-here
# Root domain for the Ahrefs SEO lookup (default: example.com)
YOUR_DOMAIN=example.com
# Directory for output files (default: ./output)
OUTPUT_DIR=./output
